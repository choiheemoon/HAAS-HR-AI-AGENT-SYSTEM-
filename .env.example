# HR AI Agent - local/default environment template
# Copy this file to `.env` and fill in real values.

# === Database (required) ===
# URL encode special characters in password: ! -> %21, @ -> %40, # -> %23
DATABASE_URL=postgresql://username:password@127.0.0.1:5433/your_database

# === Security (required in production) ===
SECRET_KEY=replace-with-random-string-32chars-or-more

# === Server ===
HOST=0.0.0.0
PORT=8000
DEBUG=True

# === Frontend URL (optional) ===
FRONTEND_URL=http://localhost:3000

# === CORS (optional, comma-separated origins) ===
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === OpenAI (optional) ===
OPENAI_API_KEY=your_openai_api_key_here
