# HR AI Agent - Windows Server 배포용 환경 변수 예시
# 이 파일을 프로젝트 루트에 .env 로 복사한 뒤 값을 수정하세요.

# === 데이터베이스 (필수) ===
# PostgreSQL 연결 (비밀번호 특수문자는 %인코딩: ! -> %21, @ -> %40, # -> %23)
DATABASE_URL=postgresql://postgres:비밀번호%21%40%23@127.0.0.1:5433/AI_HR

# === 보안 (운영 환경에서는 반드시 변경) ===
SECRET_KEY=운영용-랜덤-문자열-32자이상

# === 서버 ===
HOST=0.0.0.0
PORT=8000
DEBUG=False

# 외부 접속 시 프론트엔드 URL (공개 채용공고 링크 등)
# 예: http://서버IP:3000 또는 https://hr.example.com
FRONTEND_URL=http://localhost:3000

# 브라우저에서 API(다른 포트)로 직접 호출 시 CORS 허용 목록 (쉼표 구분, 슬래시 없이)
# NEXT_PUBLIC_API_URL 로 8080 등을 쓰는 경우, 여기에 실제 접속 Origin 과 일치하게 넣어야 합니다.
# 예: CORS_ORIGINS=http://218.151.134.47:3000,http://localhost:3000
# CORS_ORIGINS=

# === OpenAI (선택) ===
# OPENAI_API_KEY=sk-...

# === 프론트엔드 빌드 시 API URL (선택) ===
# 외부 도메인 사용 시: frontend/.env.production 에 설정
# NEXT_PUBLIC_API_URL=http://서버IP:8000
